{
  "manifest_version": 3,
  "name": "Whisper Guard",
  "version": "0.0.0",
  "description": "The Whisper security graph in your browser: a live safety verdict on every site, plus a dashboard of where your devices go.",
  "minimum_chrome_version": "121",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Whisper Guard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/signedout-16.png",
      "32": "icons/signedout-32.png",
      "48": "icons/signedout-48.png",
      "128": "icons/signedout-128.png"
    }
  },
  "icons": {
    "16": "icons/base-16.png",
    "32": "icons/base-32.png",
    "48": "icons/base-48.png",
    "128": "icons/base-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "webNavigation",
    "storage",
    "scripting",
    "contextMenus",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "https://graph.whisper.security/*",
    "https://console.whisper.security/*",
    "https://get.whisper.online/*",
    "https://rdap.whisper.online/*"
  ],
  "optional_permissions": [
    "proxy",
    "webRequest",
    "webRequestAuthProvider",
    "privacy"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "warning.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'"
  }
}
