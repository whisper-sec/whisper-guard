{
  "manifest_version": 3,
  "name": "Whisper Guard",
  "version": "0.0.0",
  "description": "Proactive phishing and brand protection. On-device look-alike detection the instant it installs; the live Whisper security graph signal when you sign in. Only a site's name is ever checked, never your browsing.",
  "browser_specific_settings": {
    "gecko": {
      "id": "guard@whisper.security",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Whisper Guard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/signedout-16.png",
      "32": "icons/signedout-32.png",
      "48": "icons/signedout-48.png",
      "128": "icons/signedout-128.png"
    }
  },
  "icons": {
    "16": "icons/base-16.png",
    "32": "icons/base-32.png",
    "48": "icons/base-48.png",
    "128": "icons/base-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "webNavigation",
    "storage",
    "scripting",
    "contextMenus",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "https://graph.whisper.security/*",
    "https://console.whisper.security/*",
    "https://get.whisper.online/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'"
  }
}
